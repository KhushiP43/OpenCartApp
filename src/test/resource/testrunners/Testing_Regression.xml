<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Opencart App Test Regression Suite" verbose="4" thread-count="2" parallel="tests">

<listeners>
		<listener
			class-name="com.aventstack.chaintest.plugins.ChainTestListener" />
			<listener class-name="ccom.qa.projectbname.listener.TestAllureListener" />
	</listeners>

	<test name="Login Page Test_chrome">
		<parameter name="browser" value="chrome" />
		<classes>
			<class name="com.qa.projectname.tests.LoginPageTest" />
		</classes>
	</test>
	
		<test name="Login Page Test_edge">
		<parameter name="browser" value="edge" />
		<classes>
			<class name="com.qa.projectname.tests.LoginPageTest" />
		</classes>
	</test>
	

	<test name="Registration Page Test">
		<parameter name="browser" value="edge" />
		<classes>
			<class name="com.qa.projectname.tests.RegistrationPageTest" />
		</classes>
	</test>


	<test name="ProductInfo Page Test">
		<parameter name="browser" value="chrome" />
		<classes>
			<class name="com.qa.projectname.tests.ProductInfoPageTest" />
		</classes>
	</test>

	<test name="Search Test">
		<parameter name="browser" value="edge" />
		<classes>
			<class name="com.qa.projectname.tests.SearchTest" />
		</classes>
	</test>

</suite>	


